# Build output
target/
**/target/
build/
**/build/
out/
**/out/
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# Compiled files
*.class

# Logs
*.log
logs/
**/logs/
.runtime/

# Local environment and secrets
.env
.env.*
*.local
application-local.properties
application-local.yml
application-local.yaml

# IDEs and editors
.idea/
*.iws
*.iml
*.ipr
.vscode/
.project
.classpath
.settings/
.factorypath
.apt_generated/
.sts4-cache/
.springBeans

# NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# OS files
.DS_Store
Thumbs.db

# Archives
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Keep Maven wrapper artifacts versioned
!.mvn/wrapper/maven-wrapper.jar
!**/.mvn/wrapper/maven-wrapper.jar

# JVM crash logs
hs_err_pid*
replay_pid*
